{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "site": "your-firebase-hosting-site",
    "public": "build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
