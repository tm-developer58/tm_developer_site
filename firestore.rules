rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Contact submissions and rate-limit state are written only by the Admin
    // SDK in submitContactMessage. Browser clients have no direct access.
    match /contactMessages/{messageId} {
      allow read, write: if false;
    }

    match /contactRateLimits/{limiterId} {
      allow read, write: if false;
    }
  }
}
